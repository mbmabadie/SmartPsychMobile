<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- معلومات التطبيق الأساسية -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>Smart Psych</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>smart_psych</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- أذونات الموقع -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>نحتاج لموقعك لتتبع نشاطك اليومي وتحليل أنماط حركتك</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>نحتاج للوصول المستمر لموقعك لتتبع نشاطك تلقائياً حتى عندما يكون التطبيق في الخلفية</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>نحتاج لموقعك للتتبع التلقائي للنشاط والنوم</string>

	<!-- أذونات الحركة والنشاط -->
	<key>NSMotionUsageDescription</key>
	<string>نحتاج للوصول لحساس الحركة لتتبع خطواتك ونشاطك البدني اليومي</string>

	<key>NSHealthShareUsageDescription</key>
	<string>نحتاج للوصول لبيانات صحتك لعرض إحصائيات نشاطك</string>

	<key>NSHealthUpdateUsageDescription</key>
	<string>نحتاج لتحديث بيانات صحتك بناءً على نشاطك</string>

	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>healthkit</string>
		<string>armv7</string>
	</array>

	<!-- أذونات الكاميرا والصور -->
	<key>NSCameraUsageDescription</key>
	<string>نحتاج للكاميرا لالتقاط الصور أو مسح الرموز</string>

	<key>NSMicrophoneUsageDescription</key>
	<string>نحتاج للميكروفون لتسجيل الملاحظات الصوتية</string>

	<key>NSPhotoLibraryUsageDescription</key>
	<string>نحتاج للوصول لمكتبة الصور لحفظ واستعراض الصور</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>نحتاج لإضافة الصور لمكتبتك</string>

	<!-- أذونات الإشعارات -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>نحتاج لإرسال إشعارات لتذكيرك بنشاطك اليومي وأهدافك الصحية</string>

	<!-- أذونات البلوتوث -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>نحتاج للبلوتوث للاتصال بأجهزة اللياقة البدنية</string>

	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>نحتاج للبلوتوث لمزامنة بياناتك مع أجهزة اللياقة</string>

	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
	</array>

	<!-- إعدادات الأمان (للتطوير فقط) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- إعدادات الواجهة -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UIStatusBarHidden</key>
	<false/>

	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- دعم Dark Mode -->
	<key>UIUserInterfaceStyle</key>
	<string>Automatic</string>

	<!-- اللغات المدعومة -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ar</string>
	</array>

	<!-- إعدادات الأيقونة -->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>Icon-App-20x20@2x</string>
				<string>Icon-App-20x20@3x</string>
				<string>Icon-App-29x29@1x</string>
				<string>Icon-App-29x29@2x</string>
				<string>Icon-App-29x29@3x</string>
				<string>Icon-App-40x40@1x</string>
				<string>Icon-App-40x40@2x</string>
				<string>Icon-App-40x40@3x</string>
				<string>Icon-App-60x60@2x</string>
				<string>Icon-App-60x60@3x</string>
				<string>Icon-App-76x76@1x</string>
				<string>Icon-App-76x76@2x</string>
				<string>Icon-App-83.5x83.5@2x</string>
				<string>Icon-App-1024x1024@1x</string>
			</array>
		</dict>
	</dict>

</dict>
</plist>